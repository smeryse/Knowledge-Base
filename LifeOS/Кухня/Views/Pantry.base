filters:
  and:
    - type == "pantry-item"
views:
  - type: table
    name: Таблица
    order:
      - file.name
      - product
      - qty_current
      - expires_on
      - manufactured_on
      - location
      - file.backlinks
    sort:
      - property: file.ctime
        direction: DESC
    columnSize:
      note.product: 296
      note.expires_on: 11
      note.manufactured_on: 61
