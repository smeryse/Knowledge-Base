views:
  - type: table
    name: Активные
    filters:
      and:
        - file.path.contains("Projects/Кухня/Shopping List")
        - type == "shopping-item"
        - status != "done"
        - status != "cancelled"
    sort:
      - property: file.name
        direction: ASC
      - property: file.mtime
        direction: DESC
